{
  "name": "blog-website-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend foundation for the monetized blog platform.",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "APP_ENV=production NODE_ENV=production node dist/main.js",
    "start:prod": "APP_ENV=production NODE_ENV=production node dist/main.js",
    "start:staging": "APP_ENV=staging NODE_ENV=production node dist/main.js",
    "start:dev": "APP_ENV=development NODE_ENV=development ts-node-dev --respawn --transpile-only src/main.ts",
    "migration:run": "APP_ENV=development NODE_ENV=development typeorm-ts-node-commonjs -d src/database/typeorm.config.ts migration:run",
    "migration:revert": "APP_ENV=development NODE_ENV=development typeorm-ts-node-commonjs -d src/database/typeorm.config.ts migration:revert",
    "migration:show": "APP_ENV=development NODE_ENV=development typeorm-ts-node-commonjs -d src/database/typeorm.config.ts migration:show",
    "migration:run:staging": "APP_ENV=staging NODE_ENV=production typeorm-ts-node-commonjs -d src/database/typeorm.config.ts migration:run",
    "migration:revert:staging": "APP_ENV=staging NODE_ENV=production typeorm-ts-node-commonjs -d src/database/typeorm.config.ts migration:revert",
    "migration:show:staging": "APP_ENV=staging NODE_ENV=production typeorm-ts-node-commonjs -d src/database/typeorm.config.ts migration:show",
    "migration:run:prod": "APP_ENV=production NODE_ENV=production typeorm -d dist/database/typeorm.config.js migration:run",
    "migration:revert:prod": "APP_ENV=production NODE_ENV=production typeorm -d dist/database/typeorm.config.js migration:revert",
    "migration:show:prod": "APP_ENV=production NODE_ENV=production typeorm -d dist/database/typeorm.config.js migration:show"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.17",
    "@types/qrcode": "^1.5.6",
    "bullmq": "^5.71.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cloudinary": "^2.9.0",
    "dotenv": "^17.3.1",
    "nodemailer": "^8.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-jwt": "^4.0.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
