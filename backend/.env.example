NODE_ENV=development
APP_PORT=3000
APP_HOST=0.0.0.0
FRONTEND_URL=http://localhost:3001

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Inkline
SMTP_FROM_EMAIL=
